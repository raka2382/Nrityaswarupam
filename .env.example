# Copy to ".env" and fill in.

# --- Supabase (database, admin login, image storage) ---
# From your Supabase project: Settings → API
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Admin access control (optional, recommended) ---
# Comma-separated allowlist. Only these emails can enter /admin (extra layer on
# top of disabling sign-ups in Supabase). Leave blank to allow any signed-in user.
ADMIN_EMAILS=

# --- Enquiry emails (optional but recommended) ---
# Free API key at https://resend.com
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=hello@nrityaswarupam.com
ENQUIRY_FROM_EMAIL=Nrityaswarupam <onboarding@resend.dev>
