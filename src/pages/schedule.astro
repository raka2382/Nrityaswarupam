---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getClasses } from "../lib/data";

const dayOrder = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

const sorted = await getClasses();

// Group classes by day, preserving day order.
const days = dayOrder
  .map((day) => ({ day, items: sorted.filter((c) => c.day === day) }))
  .filter((g) => g.items.length > 0);

const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

// Filter options are derived from the classes that actually exist, so any new
// dance form added in the admin automatically shows up here.
const danceFormOptions = Array.from(
  new Set(sorted.map((c) => c.danceForm).filter((f) => f && f !== "all"))
) as string[];
---

<BaseLayout title="Class Schedule | Nrityaswarupam" active="schedule" description="Weekly timetable of classical dance classes at Nrityaswarupam — Kathak, Bharatanatyam, Odissi and more across all skill levels.">
  <main class="flex-grow flex flex-col">
    <!-- Header -->
    <header class="w-full max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop pt-xl pb-lg relative">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-secondary/5 via-background to-background pointer-events-none"></div>
      <div class="relative z-10 flex flex-col items-center text-center max-w-3xl mx-auto">
        <div class="flex items-center justify-center gap-4 mb-sm opacity-60">
          <div class="h-px w-12 bg-secondary"></div>
          <span class="material-symbols-outlined text-secondary fill">spa</span>
          <div class="h-px w-12 bg-secondary"></div>
        </div>
        <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-secondary mb-md">
          Timetable &amp; Schedule
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">
          Discover our carefully curated sessions across various classical traditions. Find the rhythm that speaks to your soul and join our community of dedicated practitioners.
        </p>
      </div>
    </header>

    <!-- Filters -->
    <section class="w-full max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop mb-lg relative z-20">
      <div class="bg-surface-container border border-outline-variant/30 rounded-xl p-md flex flex-col md:flex-row gap-gutter items-center justify-between atmospheric-depth">
        <div class="flex flex-wrap gap-sm w-full md:w-auto">
          <div class="relative flex-grow md:flex-grow-0 min-w-[200px]">
            <label class="absolute -top-2 left-3 bg-surface-container px-1 font-label-sm text-label-sm text-secondary z-10">Dance Form</label>
            <select data-filter-form class="w-full bg-transparent border border-outline-variant rounded p-3 text-on-surface font-body-md focus:border-secondary focus:ring-1 focus:ring-secondary outline-none appearance-none cursor-pointer">
              <option value="all">All Disciplines</option>
              {danceFormOptions.map((f) => <option value={f}>{cap(f)}</option>)}
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
          </div>
          <div class="relative flex-grow md:flex-grow-0 min-w-[200px]">
            <label class="absolute -top-2 left-3 bg-surface-container px-1 font-label-sm text-label-sm text-secondary z-10">Skill Level</label>
            <select data-filter-level class="w-full bg-transparent border border-outline-variant rounded p-3 text-on-surface font-body-md focus:border-secondary focus:ring-1 focus:ring-secondary outline-none appearance-none cursor-pointer">
              <option value="all">All Levels</option>
              <option value="beginner">Beginner</option>
              <option value="intermediate">Intermediate</option>
              <option value="advanced">Advanced</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
          </div>
        </div>
        <div class="flex items-center gap-sm bg-surface-container-highest rounded-full p-1 border border-outline-variant/20">
          <button class="p-2 text-on-surface-variant hover:text-secondary transition-colors rounded-full hover:bg-surface"><span class="material-symbols-outlined">chevron_left</span></button>
          <span class="font-label-md text-label-md text-on-surface px-4">This Week</span>
          <button class="p-2 text-on-surface-variant hover:text-secondary transition-colors rounded-full hover:bg-surface"><span class="material-symbols-outlined">chevron_right</span></button>
        </div>
      </div>
    </section>

    <!-- Schedule Grid -->
    <section class="w-full max-w-7xl mx-auto px-margin-mobile md:px-margin-desktop mb-xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter" data-schedule>
        {days.map((group) => (
          <>
            <div class="lg:col-span-12 mt-md mb-sm flex items-center gap-4" data-day>
              <h2 class="font-headline-md text-headline-md text-secondary">{group.day}</h2>
              <div class="flex-grow h-px bg-gradient-to-r from-outline-variant/50 to-transparent"></div>
            </div>
            {group.items.map((c) => (
              c.featured ? (
                <div data-class-card data-form={c.danceForm} data-level={c.level} class="lg:col-span-12 xl:col-span-8 group relative overflow-hidden bg-surface-container-high border border-secondary/20 rounded-lg p-0 transition-all duration-300 hover:border-secondary atmospheric-depth flex flex-col md:flex-row">
                  <div class="md:w-2/5 relative h-48 md:h-auto overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent to-surface-container-high z-10 hidden md:block"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-surface-container-high to-transparent z-10 md:hidden block"></div>
                    {c.image && <img alt={c.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 opacity-70 group-hover:opacity-100" src={c.image} />}
                  </div>
                  <div class="md:w-3/5 p-md flex flex-col justify-center relative z-20">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="material-symbols-outlined text-secondary text-sm fill">star</span>
                      <span class="font-label-sm text-label-sm text-secondary tracking-widest uppercase">{c.instructor}</span>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-surface mb-2">{c.title}</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-md max-w-md">{c.blurb}</p>
                    <div class="mt-auto">
                      <a class="bg-transparent border border-secondary text-secondary font-label-md px-6 py-2 rounded hover:bg-secondary/10 transition-colors inline-flex items-center gap-2" href="/join">
                        Reserve Spot <span class="material-symbols-outlined text-[18px]">east</span>
                      </a>
                    </div>
                  </div>
                </div>
              ) : (
                <div data-class-card data-form={c.danceForm} data-level={c.level} class="lg:col-span-6 xl:col-span-4 group relative overflow-hidden bg-surface-container-low border border-outline-variant/30 rounded-lg p-md transition-all duration-300 hover:border-secondary/50 atmospheric-depth">
                  <div class="absolute top-0 right-0 w-32 h-32 bg-primary-container/5 rounded-bl-full pointer-events-none transition-transform duration-500 group-hover:scale-110"></div>
                  <div class="flex justify-between items-start mb-4 relative z-10">
                    <div>
                      <span class="inline-block px-2 py-1 bg-surface-variant text-on-surface-variant font-label-sm text-label-sm rounded mb-2 border border-outline-variant/20">{cap(c.level)}</span>
                      <h3 class="font-headline-sm text-headline-sm text-on-surface group-hover:text-secondary transition-colors">{c.title}</h3>
                    </div>
                    <div class="text-right">
                      <span class="block font-label-md text-label-md text-secondary">{c.time}</span>
                      <span class="block font-label-sm text-label-sm text-on-surface-variant">{c.duration}</span>
                    </div>
                  </div>
                  <div class="flex items-center gap-3 mt-md pt-4 border-t border-outline-variant/20 relative z-10">
                    {c.instructorImage ? (
                      <img alt={`${c.instructor} portrait`} class="w-10 h-10 rounded-full border border-secondary/30 object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src={c.instructorImage} />
                    ) : (
                      <div class="w-10 h-10 rounded-full border border-secondary/30 bg-surface-variant flex items-center justify-center text-secondary font-headline-sm">{c.instructor.charAt(0)}</div>
                    )}
                    <div>
                      <p class="font-label-md text-label-md text-on-surface">{c.instructor}</p>
                      <p class="font-label-sm text-label-sm text-on-surface-variant flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">location_on</span> {c.room}
                      </p>
                    </div>
                    <a class="ml-auto text-secondary hover:text-primary transition-colors" aria-label="Enquire about this class" href="/join">
                      <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                  </div>
                </div>
              )
            ))}
          </>
        ))}
      </div>
      <p data-schedule-empty class="hidden text-center font-body-md text-body-md text-on-surface-variant py-lg">No classes match your filters this week. Try a different combination, or <a class="text-secondary gold-thread" href="/join">send us an enquiry</a>.</p>
    </section>
  </main>
</BaseLayout>

<script>
  const formFilter = document.querySelector<HTMLSelectElement>("[data-filter-form]");
  const levelFilter = document.querySelector<HTMLSelectElement>("[data-filter-level]");
  const grid = document.querySelector("[data-schedule]");

  if (grid && (formFilter || levelFilter)) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>("[data-class-card]"));
    const dayHeadings = Array.from(grid.querySelectorAll<HTMLElement>("[data-day]"));
    const emptyMessage = document.querySelector("[data-schedule-empty]");
    const norm = (v: string | undefined) => (v || "all").trim().toLowerCase();

    const apply = () => {
      const form = norm(formFilter?.value);
      const level = norm(levelFilter?.value);
      let visible = 0;

      cards.forEach((card) => {
        const cf = norm(card.dataset.form);
        const cl = norm(card.dataset.level);
        const match = (form === "all" || cf === "all" || cf === form) && (level === "all" || cl === "all" || cl === level);
        card.classList.toggle("hidden", !match);
        if (match) visible++;
      });

      dayHeadings.forEach((heading) => {
        let any = false;
        let node = heading.nextElementSibling as HTMLElement | null;
        while (node && !node.hasAttribute("data-day")) {
          if (node.hasAttribute("data-class-card") && !node.classList.contains("hidden")) any = true;
          node = node.nextElementSibling as HTMLElement | null;
        }
        heading.classList.toggle("hidden", !any);
      });

      if (emptyMessage) emptyMessage.classList.toggle("hidden", visible !== 0);
    };

    formFilter?.addEventListener("change", apply);
    levelFilter?.addEventListener("change", apply);
  }
</script>
