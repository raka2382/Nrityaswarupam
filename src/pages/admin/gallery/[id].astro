---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { createSupabaseServerClient } from "../../../lib/supabase";
import { uploadMedia } from "../../../lib/storage";

const supabase = createSupabaseServerClient(Astro.request.headers, Astro.cookies);
const { id } = Astro.params;
const isNew = id === "new";
let error = "";

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  let image = String(f.get("image_url") ?? "").trim();
  try {
    const uploaded = await uploadMedia(supabase, f.get("image_file"));
    if (uploaded) image = uploaded;
  } catch (e) {
    error = e instanceof Error ? e.message : "Upload failed.";
  }
  const payload = {
    title: String(f.get("title") ?? "").trim(),
    category: String(f.get("category") ?? "Performance").trim(),
    caption: String(f.get("caption") ?? "").trim() || null,
    aspect: String(f.get("aspect") ?? "aspect-[3/4]"),
    sort_order: Number(f.get("sort_order") ?? 0) || 0,
    image,
  };
  if (!error && !payload.title) error = "Title is required.";
  if (!error && !payload.image) error = "Please upload an image or paste an image URL.";
  if (!error) {
    const res = isNew
      ? await supabase.from("gallery_items").insert(payload)
      : await supabase.from("gallery_items").update(payload).eq("id", id);
    if (res.error) error = res.error.message;
    else return Astro.redirect("/admin/gallery");
  }
}

let row: Record<string, any> = { title: "", category: "Performance", caption: "", aspect: "aspect-[3/4]", sort_order: 0, image: "" };
if (!isNew) {
  const { data } = await supabase.from("gallery_items").select("*").eq("id", id).single();
  if (data) row = data;
}

const { data: catRows } = await supabase.from("gallery_items").select("category");
const categorySuggestions = Array.from(
  new Set([
    ...(catRows ?? []).map((r) => r.category),
    "Stage Shows", "Classroom Moments", "Workshops", "Performances",
  ].filter(Boolean))
);

const aspects = ["aspect-[3/4]", "aspect-square", "aspect-[4/5]", "aspect-[16/9]"];
const field = "w-full bg-transparent border border-outline-variant rounded p-3 text-on-surface font-body-md focus:border-secondary focus:ring-1 focus:ring-secondary outline-none";
const lbl = "block font-label-sm text-label-sm text-secondary uppercase tracking-widest mb-2";
---

<AdminLayout title={isNew ? "Add photo" : "Edit photo"} active="gallery">
  <form method="POST" enctype="multipart/form-data" class="max-w-2xl space-y-md">
    {error && <p class="text-error font-body-md">{error}</p>}
    {row.image && (
      <img src={row.image} alt={row.title} class="w-40 h-40 object-cover rounded-lg border border-outline-variant/30" />
    )}
    <div>
      <label class={lbl} for="image_file">Upload a photo</label>
      <input id="image_file" name="image_file" type="file" accept="image/*" class="block w-full text-on-surface-variant font-body-md file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:bg-primary-container file:text-tertiary-fixed file:font-label-md file:cursor-pointer" />
      <p class="font-label-sm text-label-sm text-on-surface-variant/60 mt-1">{isNew ? "Choose a file from your computer." : "Leave empty to keep the current photo."}</p>
    </div>
    <div>
      <label class={lbl} for="image_url">…or paste an image URL</label>
      <input id="image_url" name="image_url" class={field} value={row.image} />
    </div>
    <div><label class={lbl} for="title">Title</label><input id="title" name="title" class={field} value={row.title} required /></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-md">
      <div>
        <label class={lbl} for="category">Category</label>
        <input id="category" name="category" list="category-list" class={field} value={row.category} placeholder="Choose or type a category" />
        <datalist id="category-list">
          {categorySuggestions.map((c) => <option value={c}></option>)}
        </datalist>
        <p class="font-label-sm text-label-sm text-on-surface-variant/60 mt-1">This becomes a filter tab on the Gallery page.</p>
      </div>
      <div>
        <label class={lbl} for="aspect">Shape</label>
        <select id="aspect" name="aspect" class={field}>
          {aspects.map((a) => <option value={a} selected={row.aspect === a}>{a}</option>)}
        </select>
      </div>
    </div>
    <div><label class={lbl} for="caption">Caption</label><textarea id="caption" name="caption" rows="2" class={field}>{row.caption ?? ""}</textarea></div>
    <div><label class={lbl} for="sort_order">Order</label><input id="sort_order" name="sort_order" type="number" class={field} value={row.sort_order} /></div>
    <div class="flex gap-md pt-sm">
      <button class="bg-primary-container text-tertiary-fixed font-label-md text-label-md px-8 py-3 rounded gold-glow border border-transparent hover:border-secondary/30">Save</button>
      <a href="/admin/gallery" class="font-label-md text-label-md text-on-surface-variant hover:text-secondary self-center">Cancel</a>
    </div>
  </form>
</AdminLayout>
