---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { createSupabaseServerClient } from "../../../lib/supabase";

const supabase = createSupabaseServerClient(Astro.request.headers, Astro.cookies);

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = String(form.get("id") ?? "");
  if (id) await supabase.from("stats").delete().eq("id", id);
  return Astro.redirect("/admin/stats");
}

const { data: items } = await supabase.from("stats").select("*").order("sort_order");
---

<AdminLayout title="Homepage Stats" active="stats">
  <p class="font-body-md text-body-md text-on-surface-variant mb-md max-w-2xl">
    The highlight numbers on the home page. Add, edit, or remove them freely — the
    row re-centers automatically for any count.
  </p>
  <div class="flex justify-end mb-md">
    <a href="/admin/stats/new" class="bg-primary-container text-tertiary-fixed font-label-md text-label-md px-6 py-3 rounded gold-glow border border-transparent hover:border-secondary/30 inline-flex items-center gap-2">
      <span class="material-symbols-outlined text-sm">add</span> Add stat
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
    {(items ?? []).map((s) => (
      <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-lg text-center relative">
        <p class="font-display-lg text-display-lg text-secondary mb-2">{s.value}</p>
        <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-widest">{s.label}</p>
        <div class="flex items-center justify-center gap-3 mt-md">
          <a href={`/admin/stats/${s.id}`} class="text-secondary hover:text-primary"><span class="material-symbols-outlined">edit</span></a>
          <form method="POST" onsubmit="return confirm('Delete this stat?')">
            <input type="hidden" name="id" value={s.id} />
            <button class="text-on-surface-variant hover:text-error"><span class="material-symbols-outlined">delete</span></button>
          </form>
        </div>
      </div>
    ))}
    {(!items || items.length === 0) && <p class="font-body-md text-on-surface-variant col-span-full">No stats yet.</p>}
  </div>
</AdminLayout>
