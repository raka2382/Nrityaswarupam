---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { createSupabaseServerClient } from "../../lib/supabase";

const supabase = createSupabaseServerClient(Astro.request.headers, Astro.cookies);

async function count(table: string) {
  const { count } = await supabase.from(table).select("*", { count: "exact", head: true });
  return count ?? 0;
}

const cards = [
  { label: "Classes", href: "/admin/classes", icon: "calendar_month", count: await count("classes") },
  { label: "Gallery", href: "/admin/gallery", icon: "photo_library", count: await count("gallery_items") },
  { label: "Instructors", href: "/admin/instructors", icon: "groups", count: await count("instructors") },
  { label: "Enquiries", href: "/admin/enquiries", icon: "mail", count: await count("enquiries") },
];
---

<AdminLayout title="Overview" active="home">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
    {cards.map((c) => (
      <a href={c.href} class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-lg hover:border-secondary/50 transition-colors atmospheric-depth">
        <span class="material-symbols-outlined text-secondary text-4xl mb-md block">{c.icon}</span>
        <p class="font-display-lg text-headline-lg text-on-surface">{c.count}</p>
        <p class="font-label-md text-label-md text-on-surface-variant uppercase tracking-widest mt-1">{c.label}</p>
      </a>
    ))}
  </div>
  <p class="font-body-md text-body-md text-on-surface-variant mt-lg">
    Manage the website's content from the tabs above. Changes appear on the live site immediately.
  </p>
</AdminLayout>
