---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { createSupabaseServerClient } from "../../../lib/supabase";
import { uploadMedia } from "../../../lib/storage";

const supabase = createSupabaseServerClient(Astro.request.headers, Astro.cookies);
const { id } = Astro.params;
const isNew = id === "new";
let error = "";

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  let photo = String(f.get("photo_url") ?? "").trim();
  try {
    const uploaded = await uploadMedia(supabase, f.get("photo_file"));
    if (uploaded) photo = uploaded;
  } catch (e) {
    error = e instanceof Error ? e.message : "Upload failed.";
  }
  const payload = {
    name: String(f.get("name") ?? "").trim(),
    title: String(f.get("title") ?? "").trim(),
    sort_order: Number(f.get("sort_order") ?? 0) || 0,
    photo: photo || null,
  };
  if (!error && !payload.name) error = "Name is required.";
  if (!error) {
    const res = isNew
      ? await supabase.from("instructors").insert(payload)
      : await supabase.from("instructors").update(payload).eq("id", id);
    if (res.error) error = res.error.message;
    else return Astro.redirect("/admin/instructors");
  }
}

let row: Record<string, any> = { name: "", title: "", sort_order: 0, photo: "" };
if (!isNew) {
  const { data } = await supabase.from("instructors").select("*").eq("id", id).single();
  if (data) row = data;
}

const field = "w-full bg-transparent border border-outline-variant rounded p-3 text-on-surface font-body-md focus:border-secondary focus:ring-1 focus:ring-secondary outline-none";
const lbl = "block font-label-sm text-label-sm text-secondary uppercase tracking-widest mb-2";
---

<AdminLayout title={isNew ? "Add instructor" : "Edit instructor"} active="instructors">
  <form method="POST" enctype="multipart/form-data" class="max-w-2xl space-y-md">
    {error && <p class="text-error font-body-md">{error}</p>}
    {row.photo && <img src={row.photo} alt={row.name} class="w-28 h-28 object-cover rounded-full border border-outline-variant/30" />}
    <div>
      <label class={lbl} for="photo_file">Upload a photo</label>
      <input id="photo_file" name="photo_file" type="file" accept="image/*" class="block w-full text-on-surface-variant font-body-md file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:bg-primary-container file:text-tertiary-fixed file:font-label-md file:cursor-pointer" />
      <p class="font-label-sm text-label-sm text-on-surface-variant/60 mt-1">{isNew ? "Choose a file from your computer." : "Leave empty to keep the current photo."}</p>
    </div>
    <div><label class={lbl} for="photo_url">…or paste a photo URL</label><input id="photo_url" name="photo_url" class={field} value={row.photo ?? ""} /></div>
    <div><label class={lbl} for="name">Name</label><input id="name" name="name" class={field} value={row.name} required /></div>
    <div><label class={lbl} for="title">Title / Role</label><input id="title" name="title" class={field} value={row.title} placeholder="Senior Faculty" /></div>
    <div><label class={lbl} for="sort_order">Order</label><input id="sort_order" name="sort_order" type="number" class={field} value={row.sort_order} /></div>
    <div class="flex gap-md pt-sm">
      <button class="bg-primary-container text-tertiary-fixed font-label-md text-label-md px-8 py-3 rounded gold-glow border border-transparent hover:border-secondary/30">Save</button>
      <a href="/admin/instructors" class="font-label-md text-label-md text-on-surface-variant hover:text-secondary self-center">Cancel</a>
    </div>
  </form>
</AdminLayout>
