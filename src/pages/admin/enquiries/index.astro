---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { createSupabaseServerClient } from "../../../lib/supabase";

const supabase = createSupabaseServerClient(Astro.request.headers, Astro.cookies);

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = String(form.get("id") ?? "");
  if (id) await supabase.from("enquiries").delete().eq("id", id);
  return Astro.redirect("/admin/enquiries");
}

const { data: enquiries } = await supabase
  .from("enquiries")
  .select("*")
  .order("created_at", { ascending: false });

const fmt = (d: string) => new Date(d).toLocaleString();
---

<AdminLayout title="Enquiries" active="enquiries">
  <div class="space-y-md">
    {(enquiries ?? []).map((e) => (
      <div class="bg-surface-container-low border border-outline-variant/30 rounded-xl p-lg">
        <div class="flex flex-wrap items-start justify-between gap-md">
          <div>
            <p class="font-headline-sm text-headline-sm text-on-surface">{e.name}</p>
            <p class="font-body-md text-body-md text-on-surface-variant">
              <a href={`mailto:${e.email}`} class="text-secondary gold-thread">{e.email}</a>
              {e.phone && <span> · {e.phone}</span>}
            </p>
          </div>
          <div class="text-right">
            <p class="font-label-sm text-label-sm text-on-surface-variant/70">{fmt(e.created_at)}</p>
            <form method="POST" onsubmit="return confirm('Delete this enquiry?')">
              <input type="hidden" name="id" value={e.id} />
              <button class="font-label-sm text-label-sm text-on-surface-variant hover:text-error mt-1">Delete</button>
            </form>
          </div>
        </div>
        {(e.dance_form || e.level) && (
          <p class="font-label-sm text-label-sm text-secondary uppercase tracking-widest mt-sm">{e.dance_form} {e.level && `· ${e.level}`}</p>
        )}
        {e.message && <p class="font-body-md text-body-md text-on-surface-variant mt-sm whitespace-pre-line">{e.message}</p>}
      </div>
    ))}
    {(!enquiries || enquiries.length === 0) && (
      <p class="font-body-md text-on-surface-variant">No enquiries yet. Submissions from the Join page will appear here.</p>
    )}
  </div>
</AdminLayout>
